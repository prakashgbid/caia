{
  "name": "caia",
  "private": true,
  "description": "CAIA \u2014 Chief AI Agent monorepo. Foundational utilities, CLI, and templates for AI-driven application development.",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish",
    "prepare": "husky || true",
    "test:regression": "pnpm --filter @caia-app/core test:regression",
    "test:regression:pipeline": "pnpm --filter @caia-app/core test:regression:pipeline",
    "test:regression:agent": "pnpm --filter @caia-app/core test:regression:agent"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "husky": "^9.1.7",
    "turbo": "^2.1.3",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.1.0"
}
