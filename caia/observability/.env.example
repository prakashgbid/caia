# caia/observability/.env.example
#
# Copy to .env.local and either:
#   (a) Run ./init-langfuse-secrets.sh to populate from Vault, or
#   (b) Hand-edit the values for a one-off bring-up.
#
# .env.local is gitignored. NEVER commit it.

# ─── Service exposure ─────────────────────────────────────────────
# UI + ingest API. Bound to 127.0.0.1 only; default 3001.
LANGFUSE_PORT=3001

# ─── Postgres (Langfuse metadata) ─────────────────────────────────
LANGFUSE_POSTGRES_DB=langfuse
LANGFUSE_POSTGRES_USER=langfuse
LANGFUSE_POSTGRES_PASSWORD=replace-via-vault

# ─── ClickHouse (trace events) ────────────────────────────────────
LANGFUSE_CLICKHOUSE_DB=default
LANGFUSE_CLICKHOUSE_USER=clickhouse
LANGFUSE_CLICKHOUSE_PASSWORD=replace-via-vault

# ─── Redis (queue between web and worker) ─────────────────────────
LANGFUSE_REDIS_PASSWORD=replace-via-vault

# ─── MinIO (S3-compatible blob store for raw events / media) ──────
LANGFUSE_MINIO_ROOT_USER=langfuse-minio-admin
LANGFUSE_MINIO_ROOT_PASSWORD=replace-via-vault

# ─── Langfuse app crypto ──────────────────────────────────────────
# 64-character hex string. Generate with:
#   openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=replace-via-vault

# Random salt for one-way hashes. Generate with:
#   openssl rand -base64 32
LANGFUSE_SALT=replace-via-vault

# NextAuth session secret. Generate with:
#   openssl rand -base64 32
LANGFUSE_NEXTAUTH_SECRET=replace-via-vault

# ─── First-run admin seed ────────────────────────────────────────
# If LANGFUSE_INIT_USER_EMAIL is set, Langfuse will provision the
# org / project / user on first boot. Subsequent restarts noop.
LANGFUSE_INIT_ORG_ID=caia
LANGFUSE_INIT_ORG_NAME=CAIA
LANGFUSE_INIT_PROJECT_ID=caia-orchestrator
LANGFUSE_INIT_PROJECT_NAME=CAIA Orchestrator

# Set these to provision the project's API keys deterministically.
# If unset, Langfuse generates random keys and you read them out of
# the UI after first login.
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=

# Admin user. Email + password are pulled from Vault at bootstrap.
LANGFUSE_INIT_USER_EMAIL=ops@caia.local
LANGFUSE_INIT_USER_NAME=CAIA Operator
LANGFUSE_INIT_USER_PASSWORD=replace-via-vault
