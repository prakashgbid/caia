+/** Deeply nested. */
+export function nested(x: number): number {
+  if (x > 0) {
+    if (x > 1) {
+      if (x > 2) {
+        if (x > 3) {
+          if (x > 4) {
+            return x * 2;
+          }
+        }
+      }
+    }
+  }
+  return 0;
+}
