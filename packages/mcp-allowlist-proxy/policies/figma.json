{
  "name": "figma",
  "description": "Third-party @anthropic/mcp-figma server. CVE-2025-53967 history (Figma MCP code execution path) — vendor under vendored-mcp/ from a pinned SHA, run inside the sandbox-exec profile, and constrain tool args to known-safe shapes. URLs are restricted to https://www.figma.com only; file IDs are constrained to the Figma file-id format.",
  "pinnedSha": "0000000000000000000000000000000000000000",
  "sourceUrl": "https://github.com/anthropic/mcp-figma",
  "trustTier": "third-party-vendored",
  "tools": [
    {
      "name": "get_file",
      "argsConstraints": {
        "fileKey": {
          "kind": "regex",
          "pattern": "^[A-Za-z0-9]{16,32}$"
        }
      },
      "maxPerTask": 30
    },
    {
      "name": "get_node",
      "argsConstraints": {
        "fileKey": {
          "kind": "regex",
          "pattern": "^[A-Za-z0-9]{16,32}$"
        },
        "nodeId": {
          "kind": "regex",
          "pattern": "^[0-9]+:[0-9]+$"
        }
      },
      "maxPerTask": 100
    },
    {
      "name": "get_image",
      "argsConstraints": {
        "fileKey": {
          "kind": "regex",
          "pattern": "^[A-Za-z0-9]{16,32}$"
        },
        "format": {
          "kind": "enum",
          "values": ["png", "jpg", "svg", "pdf"]
        }
      },
      "maxPerTask": 50
    }
  ],
  "allowedHosts": [
    "api.figma.com",
    "www.figma.com"
  ],
  "sandboxProfile": "scripts/mcp-sandbox.sb"
}
