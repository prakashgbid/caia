{
  "name": "mac-mcp",
  "description": "First-party CAIA MCP that exposes mac_bash, mac_read_file, mac_write_file, mac_list_dir, mac_grep, mac_git on the operator's MacBook. Trusted but allowlisted in defence-of-depth: tool args are constrained to forbid known prompt-injection lures and oversize blobs.",
  "pinnedSha": "44d92f1b2425ae125f67efc10dd0e37b0010ab7e",
  "sourceUrl": "https://github.com/prakashgbid/mac-mcp",
  "trustTier": "first-party-caia",
  "tools": [
    {
      "name": "mac_bash",
      "argsConstraints": {
        "command": {
          "kind": "maxLength",
          "value": 8000
        }
      },
      "maxPerTask": 200
    },
    {
      "name": "mac_read_file",
      "argsConstraints": {
        "path": {
          "kind": "regex",
          "pattern": "^/(Users/[^/]+|tmp|private/tmp|opt|var/folders)/"
        }
      },
      "maxPerTask": 500
    },
    {
      "name": "mac_write_file",
      "argsConstraints": {
        "path": {
          "kind": "regex",
          "pattern": "^/(Users/[^/]+|tmp|private/tmp|var/folders)/"
        },
        "content": {
          "kind": "maxLength",
          "value": 1048576
        }
      },
      "maxPerTask": 200
    },
    {
      "name": "mac_list_dir",
      "argsConstraints": {
        "path": {
          "kind": "regex",
          "pattern": "^/(Users/[^/]+|tmp|opt|private)"
        }
      },
      "maxPerTask": 200
    },
    {
      "name": "mac_grep",
      "argsConstraints": {
        "path": {
          "kind": "regex",
          "pattern": "^/(Users/[^/]+|tmp|private)"
        }
      },
      "maxPerTask": 200
    },
    {
      "name": "mac_git",
      "argsConstraints": {
        "cwd": {
          "kind": "regex",
          "pattern": "^/(Users/[^/]+|tmp)"
        }
      },
      "maxPerTask": 200
    }
  ],
  "allowedHosts": [
    "127.0.0.1",
    "localhost"
  ],
  "sandboxProfile": "scripts/mcp-sandbox.sb"
}
