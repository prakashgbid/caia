{
  "name": "@chiefaia/cli",
  "version": "0.1.0",
  "description": "CAIA CLI — scaffold utilities, sites, and agents",
  "type": "module",
  "bin": {
    "caia": "./bin/caia.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "bin"],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.chmodSync('bin/caia.js','755')\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@chiefaia/eslint-config": "workspace:*",
    "@chiefaia/tsconfig": "workspace:*",
    "@chiefaia/vitest-config": "workspace:*",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
