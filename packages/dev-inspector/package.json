{
  "name": "@chiefaia/dev-inspector",
  "version": "0.2.0",
  "private": true,
  "description": "Dev-only React inspector panel: tabbed dashboard for accessibility, integrity, console, network, and Core Web Vitals. Cmd+Shift+I to toggle.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test tests/e2e"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "axe-core": ">=4.0.0",
    "web-vitals": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "axe-core": { "optional": true },
    "web-vitals": { "optional": true }
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "axe-core": "^4.11.3",
    "jsdom": "^24.1.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "web-vitals": "^4.2.4",
    "@vitejs/plugin-react": "^4.3.0"
  },
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}
