{
  "name": "@chiefaia/metrics",
  "version": "0.2.0",
  "description": "Prometheus-compatible application metrics",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
