{
  "name": "@chiefaia/ticket-template",
  "version": "0.2.0",
  "private": true,
  "description": "Strict, Zod-validated ticket template (v1) \u2014 the contract between Phase 1 agents (PO, BA, EA, DBA, BFF, UI, Security, Testing, Release) and the executor.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
