#!/bin/bash
# launchd-driven wake for the {{CHAIN_ID}} chain.
#
# Generated by `caia-chain bootstrap-new-chain` at {{GENERATED_AT}}.
# Edit the template at packages/chain-runner/bin/templates/wake.sh.template
# if you need behavior changes that should apply to all chains.

set -u

CHAIN_ID="{{CHAIN_ID}}"
PHASES_FILE="{{PHASES_FILE}}"
RUNNER_SCRIPT="{{RUNNER_SCRIPT}}"
CAIA_CHAIN_BIN="{{CAIA_CHAIN_BIN}}"
NODE_BIN="${NODE_BIN:-/opt/homebrew/opt/node@22/bin/node}"
[ -x "$NODE_BIN" ] || NODE_BIN="/opt/homebrew/bin/node"

WATCHDOG_LOG_DIR="$HOME/.caia/chain-watchdog/logs"
mkdir -p "$WATCHDOG_LOG_DIR"
WATCHDOG_LOG="$WATCHDOG_LOG_DIR/{{LOG_SLUG}}_$(date -u +%Y-%m-%d).log"

# Subscription-only constraint (standing rule, 2026-05-12).
unset ANTHROPIC_API_KEY
unset ANTHROPIC_KEY

export PATH="/opt/homebrew/bin:$PATH"

# Shared helpers: reap_at_wake, respect_paused_until, preflight_gate, ts, run_chain.
# shellcheck source=/Users/macbook32/.caia/chain-watchdog/_wake_helpers.sh
source "$HOME/.caia/chain-watchdog/_wake_helpers.sh"

echo "[$(ts)] {{CHAIN_ID}} watchdog wake start" >> "$WATCHDOG_LOG"

# H-6: reap orphan workers before any dispatch logic.
reap_at_wake

# D-4: respect paused_until — auto-resume past it, else exit.
if ! respect_paused_until; then
  exit 0
fi

run_chain wake-observed >> "$WATCHDOG_LOG" 2>&1 || echo "[$(ts)] wake-observed failed" >> "$WATCHDOG_LOG"
run_chain check-lock-staleness >> "$WATCHDOG_LOG" 2>&1 || echo "[$(ts)] check-lock-staleness failed" >> "$WATCHDOG_LOG"
# H-21: explicit failed→blocked promotion before the read-only next-phase.
run_chain promote-blocked >> "$WATCHDOG_LOG" 2>&1 || echo "[$(ts)] promote-blocked failed" >> "$WATCHDOG_LOG"

NEXT=$(run_chain next-phase 2>>"$WATCHDOG_LOG")
echo "[$(ts)] next-phase: $NEXT" >> "$WATCHDOG_LOG"

case "$NEXT" in
  NONE_ELIGIBLE)
    # H-5: silent stall escalation after streak >= 2.
    echo "[$(ts)] NONE_ELIGIBLE — invoking check-stall --alert-on-streak 2" >> "$WATCHDOG_LOG"
    run_chain check-stall \
      --wake-interval-sec 900 \
      --inbox "$HOME/.caia/chain-watchdog/INBOX.md" \
      --alert-on-streak 2 \
      >> "$WATCHDOG_LOG" 2>&1 || true
    exit 0 ;;
  PAUSED|BUDGET_EXHAUSTED|ALL_DONE)
    echo "[$(ts)] noop: $NEXT" >> "$WATCHDOG_LOG"
    exit 0 ;;
  IN_PROGRESS*)
    echo "[$(ts)] noop: $NEXT" >> "$WATCHDOG_LOG"
    exit 0 ;;
  BACKOFF*)
    echo "[$(ts)] noop: $NEXT" >> "$WATCHDOG_LOG"
    exit 0 ;;
  ''|*[!0-9]*)
    # H-31: fail loud on an unrecognised next-phase output.
    echo "[$(ts)] FAIL: unrecognised next-phase output '$NEXT'" >> "$WATCHDOG_LOG"
    run_chain emit-alert \
      --type chain_wake_unrecognized_next_phase \
      --severity high \
      --detail "next-phase printed '$NEXT' which the wake script does not handle" \
      --evidence "next_phase_raw=$NEXT" \
      >> "$WATCHDOG_LOG" 2>&1 || true
    exit 1 ;;
esac

PHASE_ID="$NEXT"
echo "[$(ts)] dispatching phase $PHASE_ID" >> "$WATCHDOG_LOG"

# H-4: preflight gate — refuse to dispatch when claude is rate-limited /
# auth-failing / API-key-leaking.
if ! preflight_gate; then
  exit 0
fi

DISPATCH_OUT=$(run_chain dispatch "$PHASE_ID" --spawn "$RUNNER_SCRIPT" 2>>"$WATCHDOG_LOG")
echo "[$(ts)] dispatch result: $DISPATCH_OUT" >> "$WATCHDOG_LOG"

exit 0
