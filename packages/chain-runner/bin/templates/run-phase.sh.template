#!/bin/bash
# {{CHAIN_ID}} chain — run-phase dispatcher
#
# Generated by `caia-chain bootstrap-new-chain` at {{GENERATED_AT}}.
# Invoked by `caia-chain dispatch <phase-id> --spawn <this-script>` with
# three positional args: PHASE_ID, SESSION_ID, PROMPT_FILE.

set -euo pipefail

PHASE_ID="$1"
SESSION_ID="$2"
PROMPT_FILE="$3"

CHAIN_ID="{{CHAIN_ID}}"
PHASES_FILE="{{PHASES_FILE}}"
CAIA_CHAIN="{{CAIA_CHAIN_BIN}}"
NODE_BIN="${NODE_BIN:-/opt/homebrew/opt/node@22/bin/node}"
[ -x "$NODE_BIN" ] || NODE_BIN="/opt/homebrew/bin/node"

LOG_DIR="{{PHASE_LOG_DIR}}"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/phase${PHASE_ID}_${SESSION_ID}.log"

echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] phase=$PHASE_ID session=$SESSION_ID prompt_file=$PROMPT_FILE starting" | tee -a "$LOG_FILE"

# H-12: worker-level heartbeat between tool turns, also belt-and-suspenders
# from the dispatcher subshell.
(
  while true; do
    "$NODE_BIN" "$CAIA_CHAIN" heartbeat "$SESSION_ID" \
      --chain-id "$CHAIN_ID" \
      --phases "$PHASES_FILE" 2>/dev/null || true
    sleep 60
  done
) &
HEARTBEAT_PID=$!
trap "kill $HEARTBEAT_PID 2>/dev/null || true" EXIT

if [ ! -r "$PROMPT_FILE" ]; then
  echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] ERROR: prompt file unreadable: $PROMPT_FILE" | tee -a "$LOG_FILE"
  "$NODE_BIN" "$CAIA_CHAIN" mark-failed "$PHASE_ID" \
    --chain-id "$CHAIN_ID" \
    --phases "$PHASES_FILE" \
    "prompt_file_unreadable" 2>/dev/null || true
  exit 2
fi

# Subscription billing + bypassPermissions (standing rules).
#
# GB-3 (2026-05-16): prefer `claude-wrap` over raw `claude` so prompts pass
# through the local-llm-router at :7411 first and only escalate to the real
# claude binary on cascade fall-through. The wrapper is interface-compatible
# with `claude --print`; if it isn't installed, we fall back to vanilla
# `claude` so a missing wrapper doesn't break in-flight dispatch.
CLAUDE_BIN="${CLAUDE_BIN:-$(command -v claude-wrap || command -v claude)}"
"$CLAUDE_BIN" \
  --permission-mode bypassPermissions \
  --print \
  --output-format text \
  --max-turns 200 \
  < "$PROMPT_FILE" 2>&1 | tee -a "$LOG_FILE"

CLAUDE_EXIT="${PIPESTATUS[0]}"
echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] phase=$PHASE_ID session=$SESSION_ID claude_exit=$CLAUDE_EXIT" | tee -a "$LOG_FILE"

# Fast 5xx detection — catches API Error: 529/503/502/500/504 markers so
# H-9 retry-policy fires immediately instead of waiting for H-11.
source "$HOME/.caia/chain-watchdog/_dispatcher_helpers.sh"
if detect_server_error; then
  mark_failed_transient_server_error
fi

exit "$CLAUDE_EXIT"
