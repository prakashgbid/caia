# ════════════════════════════════════════════════════════════
#  @pokerzeno/image-provider — Environment Configuration
# ════════════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in your credentials.
#  Never commit .env to version control.

# ─── Web Sources ─────────────────────────────────────────────────────────────
#
#  These three sources are queried in parallel for every acquire request.
#  All are FREE to use at hobby/low volume. Attribution is NOT required
#  (Unsplash / Pexels / Pixabay licenses all permit commercial use without credit).
#
#  If a key is missing, that source is skipped with a warning — the CLI will
#  still work with the remaining sources.

# Unsplash — https://unsplash.com/developers
#   Free plan: 50 requests/hour. Commercial use OK.
#   Sign up → create an app → copy "Access Key"
UNSPLASH_ACCESS_KEY=

# Pexels — https://www.pexels.com/api/
#   Free plan: 200 requests/hour. Commercial use OK.
#   Sign up → API → copy key
PEXELS_API_KEY=

# Pixabay — https://pixabay.com/api/docs/
#   Free plan: 100 requests/minute. Commercial use OK.
#   Sign up → API key shown in your profile
PIXABAY_API_KEY=

# ─── AI Generation (fal.ai) ──────────────────────────────────────────────────
#
#  Used ONLY when no web candidate passes validation.
#  FLUX.1-pro  (hero images):  ~$0.05 per image
#  FLUX.1-schnell (standard):  ~$0.003 per image
#
#  Hard budget cap: $1.00 total (BUDGET_CAP_USD below).
#  The CLI refuses to generate once the cap is hit.
#
#  fal.ai — https://fal.ai/dashboard/keys
#   Sign up → API Keys → Create key
#   Add credit at https://fal.ai/billing (suggested: $5 starter)
FAL_KEY=

# ─── Cloudflare R2 Storage ───────────────────────────────────────────────────
#
#  R2 Free tier: 10 GB storage, 10M Class A ops/month, 100M Class B ops/month.
#  Suitable for hundreds of images at no cost.
#
#  Setup steps:
#   1. Create a Cloudflare account at https://dash.cloudflare.com/
#   2. Account ID: shown in the right sidebar of your dashboard
#   3. Create an R2 bucket: R2 → Create bucket (e.g. "image-provider")
#   4. Enable public access on the bucket (Settings → Public access → Allow)
#   5. Copy the public URL shown (format: https://pub-xxx.r2.dev)
#   6. Create API token: R2 → Manage R2 API tokens → Create token
#      → Permissions: "Object Read & Write" on your bucket
#      → Copy "Access Key ID" and "Secret Access Key"

CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Your bucket name (must match what you created in step 3)
R2_BUCKET=image-provider

# Public URL for your bucket (from step 5 above)
# Format: https://pub-xxxxxxxxxxxxxxxxxxxx.r2.dev
#     OR: https://images.yourdomain.com  (custom domain)
R2_PUBLIC_BASE_URL=

# ─── Storage Backend ─────────────────────────────────────────────────────────
#
#  'r2'               = Cloudflare R2 (default, free tier, fully implemented)
#  'cloudflare-images' = Cloudflare Images (stub — not yet implemented)
#
STORAGE_BACKEND=r2

# ─── Budget Cap ──────────────────────────────────────────────────────────────
#
#  Hard cap for AI generation spend (USD). The CLI will REFUSE to generate
#  once this limit is reached — it is not a soft warning.
#  Default: $1.00. Raise only with full intention.
#
BUDGET_CAP_USD=1.00
