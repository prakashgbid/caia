{
  "name": "@chiefaia/story-decomposer",
  "version": "0.1.0",
  "private": true,
  "description": "Decomposes high-level feature stories into structured implementation tasks with acceptance criteria",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "echo 'TODO: jest config not viable in new monorepo layout. Stubbed until repair or vitest migration.' && exit 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "nanoid": "^3.3.7"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0"
  }
}