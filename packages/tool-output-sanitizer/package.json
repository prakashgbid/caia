{
  "name": "@chiefaia/tool-output-sanitizer",
  "version": "0.1.0",
  "description": "Deterministic prompt-injection defense. Strips role-impersonation markers, [INST] blocks, ignore-previous-instructions variants, zero-width Unicode, ANSI escapes, and tool-redefinition payloads from MCP/HTTP/file-read responses BEFORE they reach the agent's context window.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "corpus"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@chiefaia/eslint-config": "workspace:*",
    "@chiefaia/tsconfig": "workspace:*",
    "@chiefaia/vitest-config": "workspace:*",
    "@types/node": "^20",
    "typescript": "^5.4.5",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
