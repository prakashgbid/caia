{
  "name": "@chiefaia/decomposer",
  "version": "0.1.0",
  "description": "AI-driven hierarchy decomposer — breaks natural language prompts into Initiative → Epic → Module → Story → Task",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "typescript": ">=5.0"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*",
    "vitest": "*"
  }
}
