{
  "name": "@caia/design-ingest",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-source design-ingest framework: validate / parse / snapshot adapter contract, registry dispatch, ux_uploads persistence, GDPR delete-all-for-tenant orchestration. Wraps @caia/atlas-design-snapshotter for versioning + @chiefaia/atlas-mapper for stable DOM-ID assignment. CAIA Step 5. No LLM calls.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "migrations",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@caia/atlas-design-snapshotter": "workspace:*",
    "@caia/secrets-adapter": "workspace:*",
    "@chiefaia/atlas-mapper": "workspace:*",
    "pg": "^8.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@chiefaia/eslint-config": "workspace:*",
    "@chiefaia/tsconfig": "workspace:*",
    "@chiefaia/vitest-config": "workspace:*",
    "@types/node": "^20",
    "@types/pg": "^8.11.6",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "license": "MIT"
}
