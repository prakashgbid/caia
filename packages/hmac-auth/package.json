{
  "name": "@chiefaia/hmac-auth",
  "version": "0.1.0",
  "description": "Shared HMAC-SHA256 primitives and timestamped request signing for CAIA services. Lifted from @chiefaia/mentor-event-bus auth so the same hardened implementation backs both event-bus HTTP request signing and the capability-broker token signatures. Mandatory auth: callers refuse to run without a configured secret.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {},
  "devDependencies": {
    "@chiefaia/eslint-config": "workspace:*",
    "@chiefaia/tsconfig": "workspace:*",
    "@chiefaia/vitest-config": "workspace:*",
    "@types/node": "^20",
    "typescript": "^5.4.5",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
