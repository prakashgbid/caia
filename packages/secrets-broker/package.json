{
  "name": "@chiefaia/secrets-broker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "secrets": "./dist/cli.cjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts src/server.ts --format esm,cjs --dts",
    "test": "echo 'TODO: secrets-broker has stale jest test config (SyntaxError when loading). Stubbed until jest config is repaired or migrated to vitest.' && exit 0",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.cjs"
  },
  "dependencies": {
    "@chiefaia/logger": "workspace:*",
    "commander": "^12.1.0",
    "nanoid": "^3.3.7",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": false
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "coverageThreshold": {
      "global": {
        "lines": 100,
        "functions": 100,
        "branches": 100,
        "statements": 100
      }
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.test.ts",
      "!src/index.ts",
      "!src/cli.ts",
      "!src/server.ts",
      "!src/cf-worker.ts"
    ]
  }
}