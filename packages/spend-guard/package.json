{
  "name": "@chiefaia/spend-guard",
  "version": "0.1.0",
  "description": "Programmatic Anthropic-spend cap with hard auto-pause + serial account-pool fallback (per v2 §6). Tracks token spend in real-time via response headers, enforces per-task / per-project / global-day / global-week budgets, and pauses the orchestrator when caps are breached. ToS-aware: warns once if multi-account pool is configured.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "migrations"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@chiefaia/eslint-config": "workspace:*",
    "@chiefaia/tsconfig": "workspace:*",
    "@chiefaia/vitest-config": "workspace:*",
    "@types/node": "^20",
    "typescript": "^5.4.5",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
