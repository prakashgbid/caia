{
  "name": "@pokerzeno/content-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Automated content generation for PokerZeno and Roulette Community",
  "main": "dist/cli.js",
  "bin": {
    "content": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "seed:poker": "node dist/cli.js generate --site poker --all",
    "seed:roulette": "node dist/cli.js generate --site roulette --all",
    "seed:all": "npm run build && npm run seed:poker && npm run seed:roulette"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}
