{
  "name": "@chiefaia/tracing",
  "version": "0.3.1",
  "description": "OpenTelemetry distributed tracing for the CAIA spine. Provides init / withSpan / W3C TraceContext inject+extract / NATS span helpers + wizard claude-spawner span wrapper + pg/http/undici auto-instrumentations. Canonical reuse target (no parallel @chiefaia/otel).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.7.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.32.0"
  },
  "peerDependencies": {
    "@opentelemetry/instrumentation-http": "*",
    "@opentelemetry/instrumentation-pg": "*",
    "@opentelemetry/instrumentation-undici": "*"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/instrumentation-http": { "optional": true },
    "@opentelemetry/instrumentation-pg": { "optional": true },
    "@opentelemetry/instrumentation-undici": { "optional": true }
  },
  "devDependencies": {
    "@chiefaia/eslint-config": "workspace:*",
    "@chiefaia/tsconfig": "workspace:*",
    "@chiefaia/vitest-config": "workspace:*",
    "@opentelemetry/context-async-hooks": "^2.7.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
