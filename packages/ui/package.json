{
  "name": "@caia/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Canonical shadcn/Tailwind component library for CAIA apps. Operator-locked 2026-05-25 — every UI primitive in @caia/* apps must come from here, not raw shadcn/Radix/Tailwind imports. See ADR-061 + ADR-065.",
  "keywords": [
    "ui",
    "shadcn",
    "radix",
    "tailwind",
    "components",
    "button",
    "card",
    "input",
    "form",
    "dialog",
    "accordion",
    "tabs",
    "badge",
    "progress",
    "sheet",
    "scroll-area"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles/globals.css",
    "./tailwind.config": "./tailwind.config.ts",
    "./components.json": "./components.json"
  },
  "files": [
    "dist",
    "src/styles/globals.css",
    "tailwind.config.ts",
    "components.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json || true",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0 || true",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "typescript": "^5.4.5",
    "vitest": "^1.4.0"
  }
}
