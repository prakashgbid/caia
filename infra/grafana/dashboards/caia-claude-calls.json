  "description": "Phase C2 — @chiefaia/claude-spawner instrumentation. All `claude.spawn` spans: rate per hour, P95 duration, error rate, broken down by claude.model. Sourced from Tempo.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "description": "Count of claude.spawn spans bucketed by hour. Broken down by claude.model attribute (opus, sonnet, haiku, etc.).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "spawns / interval",
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceqlMetrics",
          "query": "{ name = \"claude.spawn\" } | rate() by (span.claude.model)",
          "refId": "A"
        }
      ],
      "title": "claude.spawn count per hour (by model)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "description": "P95 span duration for `claude.spawn`, grouped by claude.model.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "p95 duration",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "ns"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceqlMetrics",
          "query": "{ name = \"claude.spawn\" } | quantile_over_time(duration, .95) by (span.claude.model)",
          "refId": "A"
        }
      ],
      "title": "claude.spawn P95 duration (by model)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "description": "Rate of claude.spawn spans with status = error, grouped by claude.model.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "errors/s",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceqlMetrics",
          "query": "{ name = \"claude.spawn\" && status = error } | rate() by (span.claude.model)",
          "refId": "A"
        }
      ],
      "title": "claude.spawn error rate (by model)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "description": "Recent claude.spawn invocations — useful for confirming model selection and spawn outcomes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true, "inspect": false },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Duration" },
            "properties": [{ "id": "unit", "value": "ns" }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 18 },
      "id": 4,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Start time" }]
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ name = \"claude.spawn\" }",
          "limit": 25,
          "tableType": "spans",
          "refId": "A"
        }
      ],
      "title": "Recent claude.spawn spans",
      "type": "table"
    }
